import { ScrollView } from "std-widgets.slint";

// ── Design tokens ─────────────────────────────────────────────────────────────

global Theme {
    out property <color> background:       #1c1c1e;
    out property <color> surface:          #2c2c2e;
    out property <color> surface-elevated: #3a3a3c;
    out property <color> border:           #3a3a3c;
    out property <color> accent:           #0a84ff;
    out property <color> accent-dim:       #0a84ff18;
    out property <color> success:          #30d158;
    out property <color> warning:          #ffd60a;
    out property <color> error:            #ff453a;
    out property <color> text-primary:     #f2f2f7;
    out property <color> text-secondary:   #ebebf5aa;
    out property <color> text-tertiary:    #ebebf544;
    out property <color> outlook-color:    #0072c6;
    out property <color> google-color:     #4285f4;
}

// ── Data types ────────────────────────────────────────────────────────────────

export enum SyncStatus { Idle, Syncing, Success, Error }

export enum SyncedItemStatus { Ok, Conflict, Error, Skipped }

export struct SyncedItem {
    subject:  string,
    status:   SyncedItemStatus,
    time-ago: string,
}

export struct SyncPair {
    source-name:    string,
    source-account: string,
    source-color:   color,
    dest-name:      string,
    dest-account:   string,
    dest-color:     color,
    /// CalDAV collection URL of the destination Google Calendar.
    dest-id:        string,
}

// ── Sync indicator ────────────────────────────────────────────────────────────

component SyncIndicator {
    in property <SyncStatus> status;
    callback clicked;

    width: 20px;
    height: 20px;

    property <angle> hover-angle: t.has-hover && status != SyncStatus.Syncing ? 30deg : 0deg;
    animate hover-angle { duration: 200ms; easing: ease-out; }

    Image {
        width: 20px; height: 20px;
        source: @image-url("../assets/sync.svg");
        image-fit: contain;
        colorize: status == SyncStatus.Error                    ? Theme.error
                : (status == SyncStatus.Syncing || t.has-hover) ? Theme.accent
                : Theme.text-tertiary;
        animate colorize { duration: 150ms; }
        transform-rotation: status == SyncStatus.Syncing
            ? animation-tick() / 900ms * 360deg
            : hover-angle;
        transform-origin: { x: 10px, y: 10px };
    }

    Rectangle {
        width: 6px; height: 6px;
        border-radius: 3px;
        background: Theme.success;
        x: (parent.width  - self.width)  / 2;
        y: (parent.height - self.height) / 2;
        visible: status == SyncStatus.Success && !t.has-hover;
    }

    t := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}

// ── SVG icon button ───────────────────────────────────────────────────────────

component SvgIconBtn {
    in property <image>  icon;
    in property <length> icon-size:  20px;
    in property <color>  idle-color: Theme.text-secondary;
    in property <color>  hot-color:  Theme.text-primary;
    in property <color>  hot-bg:     Theme.surface-elevated;
    /// Expose hover state so parent can include it in zone-hover logic.
    out property <bool>  hovered:    t.has-hover;
    callback clicked;

    width: 38px;
    height: 38px;

    Rectangle {
        border-radius: 8px;
        background: t.has-hover ? root.hot-bg : transparent;
        animate background { duration: 100ms; }

        Image {
            width: root.icon-size;
            height: root.icon-size;
            source: root.icon;
            image-fit: contain;
            colorize: t.has-hover ? root.hot-color : root.idle-color;
            animate colorize { duration: 100ms; }
        }
    }

    t := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}

// ── Compact icon button (for card overlays) ───────────────────────────────────

component CardIconBtn {
    in property <image>  icon;
    in property <length> btn-size:   24px;
    in property <length> icon-size:  13px;
    in property <color>  idle-color: Theme.text-secondary;
    in property <color>  hot-color:  Theme.text-primary;
    in property <color>  hot-bg:     Theme.surface-elevated;
    out property <bool>  hovered:    t.has-hover;
    callback clicked;

    width: btn-size;
    height: btn-size;

    Rectangle {
        border-radius: 5px;
        background: t.has-hover ? root.hot-bg : transparent;
        animate background { duration: 80ms; }

        Image {
            width: root.icon-size; height: root.icon-size;
            source: root.icon;
            image-fit: contain;
            colorize: t.has-hover ? root.hot-color : root.idle-color;
            animate colorize { duration: 80ms; }
        }
    }

    t := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}

// ── Toggle switch ─────────────────────────────────────────────────────────────

component SettingsToggle {
    in-out property <bool> checked: false;
    callback toggled(bool);

    width: 40px;
    height: 22px;

    Rectangle {
        border-radius: 11px;
        background: checked ? Theme.accent : Theme.border;
        animate background { duration: 150ms; }

        Rectangle {
            width: 18px; height: 18px;
            border-radius: 9px;
            background: Theme.text-primary;
            x: checked ? parent.width - self.width - 2px : 2px;
            y: 2px;
            animate x { duration: 150ms; easing: ease-in-out; }
        }
    }

    t := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }
}

// ── Hover-reveal overlay (gradient panel + stacked edit/trash buttons) ────────

component CardOverlay inherits Rectangle {
    in property <color> accent-color;
    in property <bool>  card-hovered;
    callback edit();
    callback clear();

    width: 60px;
    background: @linear-gradient(90deg, transparent, accent-color.with-alpha(0.35));
    opacity: card-hovered || ov-edit.hovered || ov-del.hovered ? 1.0 : 0.0;
    animate opacity { duration: 150ms; }

    ov-edit := CardIconBtn {
        x: parent.width - self.width - 6px;
        y: parent.height / 2 - self.height - 2px;
        icon: @image-url("../assets/edit.svg");
        idle-color: Theme.text-secondary;
        hot-color: Theme.text-primary;
        hot-bg: root.accent-color.with-alpha(0.35);
        clicked => { root.edit(); }
    }
    ov-del := CardIconBtn {
        x: parent.width - self.width - 6px;
        y: parent.height / 2 + 2px;
        icon: @image-url("../assets/trash.svg");
        idle-color: Theme.text-secondary;
        hot-color: Theme.error;
        hot-bg: #ff453a22;
        clicked => { root.clear(); }
    }
}

// ── Single sync pair row ──────────────────────────────────────────────────────

component PairRow {
    in property <SyncPair> pair;
    callback configure-source();
    callback configure-dest();
    callback delete();           // removes the whole pair
    callback clear-source();     // clears just the source side
    callback clear-dest();       // clears just the dest side

    property <bool> src-configured: pair.source-name != "";
    property <bool> dst-configured: pair.dest-name   != "";

    HorizontalLayout {
        spacing: 12px;

        // ── Source card ───────────────────────────────────────────────────────
        Rectangle {
            horizontal-stretch: 1;
            border-radius: 10px;
            background: src-configured
                ? pair.source-color.with-alpha(src-t.has-hover ? 0.18 : 0.10)
                : (src-t.has-hover ? Theme.surface-elevated : Theme.surface);
            animate background { duration: 100ms; }
            clip: true;

            // Empty "+" placeholder
            if !src-configured: VerticalLayout {
                alignment: center;
                padding: 8px;
                Text {
                    text: "+";
                    color: src-t.has-hover ? Theme.accent : Theme.text-tertiary;
                    font-size: 22px; font-weight: 300;
                    horizontal-alignment: center;
                    animate color { duration: 100ms; }
                }
            }

            // Configured content
            if src-configured: HorizontalLayout {
                padding-top: 8px; padding-bottom: 8px;
                padding-left: 12px; padding-right: 10px;
                spacing: 10px;
                Rectangle {
                    width: 28px;
                    Image {
                        source: @image-url("../assets/outlook.svg");
                        width: 28px; height: 28px;
                        image-fit: contain;
                        colorize: pair.source-color;
                        y: (parent.height - self.height) / 2;
                    }
                }
                VerticalLayout {
                    alignment: center;
                    spacing: 2px;
                    horizontal-stretch: 1;
                    Text {
                        text: "Outlook";
                        color: pair.source-color;
                        font-size: 13px; font-weight: 600;
                        overflow: elide;
                    }
                    Text {
                        text: pair.source-account;
                        color: Theme.text-secondary;
                        font-size: 11px;
                        overflow: elide;
                    }
                }
            }

            // Left accent bar
            if src-configured: Rectangle {
                x: 0px; y: 0px;
                width: 4px; height: parent.height;
                background: pair.source-color;
            }

            src-t := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.configure-source(); }
            }

            if src-configured: CardOverlay {
                x: parent.width - self.width;
                height: parent.height;
                accent-color: pair.source-color;
                card-hovered: src-t.has-hover;
                edit  => { root.configure-source(); }
                clear => { root.clear-source(); }
            }
        }

        // Arrow
        Rectangle {
            width: 24px;
            Image {
                source: @image-url("../assets/arrow-right.svg");
                width: 16px; height: 16px;
                image-fit: contain;
                colorize: Theme.text-tertiary;
                x: (parent.width  - self.width)  / 2;
                y: (parent.height - self.height) / 2;
            }
        }

        // ── Destination card ──────────────────────────────────────────────────
        Rectangle {
            horizontal-stretch: 1;
            border-radius: 10px;
            background: dst-configured
                ? pair.dest-color.with-alpha(dst-t.has-hover ? 0.18 : 0.10)
                : (dst-t.has-hover ? Theme.surface-elevated : Theme.surface);
            animate background { duration: 100ms; }
            clip: true;

            if !dst-configured: VerticalLayout {
                alignment: center;
                padding: 8px;
                Text {
                    text: "+";
                    color: dst-t.has-hover ? Theme.accent : Theme.text-tertiary;
                    font-size: 22px; font-weight: 300;
                    horizontal-alignment: center;
                    animate color { duration: 100ms; }
                }
            }

            if dst-configured: HorizontalLayout {
                padding-top: 8px; padding-bottom: 8px;
                padding-left: 12px; padding-right: 10px;
                spacing: 10px;
                Rectangle {
                    width: 28px;
                    Image {
                        source: @image-url("../assets/gcal.svg");
                        width: 28px; height: 28px;
                        image-fit: contain;
                        y: (parent.height - self.height) / 2;
                    }
                }
                VerticalLayout {
                    alignment: center;
                    spacing: 2px;
                    horizontal-stretch: 1;
                    Text {
                        text: "Google";
                        color: pair.dest-color;
                        font-size: 13px; font-weight: 600;
                        overflow: elide;
                    }
                    Text {
                        text: pair.dest-name;
                        color: Theme.text-secondary;
                        font-size: 11px;
                        overflow: elide;
                    }
                }
            }

            if dst-configured: Rectangle {
                x: 0px; y: 0px;
                width: 4px; height: parent.height;
                background: pair.dest-color;
            }

            dst-t := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.configure-dest(); }
            }

            if dst-configured: CardOverlay {
                x: parent.width - self.width;
                height: parent.height;
                accent-color: pair.dest-color;
                card-hovered: dst-t.has-hover;
                edit  => { root.configure-dest(); }
                clear => { root.clear-dest(); }
            }
        }
    }
}

// ── Main panel ────────────────────────────────────────────────────────────────

export component TrayPanel inherits Window {
    title: "ruscal";
    icon: @image-url("../assets/icon.svg");
    width: 520px;
    min-height: 360px;
    no-frame: true;
    background: transparent;
    always-on-top: true;

    callback sync-now();
    callback configure-source(int);
    callback configure-dest(int);
    callback delete-pair(int);
    callback clear-source(int);
    callback clear-dest(int);
    callback open-settings();
    callback minimize();
    callback quit();

    property <bool> show-quit-dialog: false;

    in property <SyncStatus>  sync-status:    SyncStatus.Idle;
    in property <string>      last-sync-text: "No pairs configured";
    in-out property <[SyncPair]> pairs;

    in-out property <int>      current-page:      0;
    in-out property <int>      config-pair-index: 0;

    // Page 1 — Outlook source picker
    in property <[string]>  outlook-calendars;
    callback source-selected(int);

    // Page 2 — Destination provider picker
    callback dest-provider-selected(int); // 0 = Google Calendar

    // Page 3 — Google Calendar picker
    in property <[string]>  google-calendars;
    in property <[string]>  google-calendar-ids;
    in property <string>    google-status: "";
    in property <string>    google-account-email: "";
    in property <[string]>  google-accounts;
    callback dest-selected(int);
    callback switch-google-account(string); // switch to an existing connected account
    callback settings-google-sign-out();    // add a new account (OAuth) while on page 3

    // Page 4 — Settings
    in-out property <int>  sync-interval-minutes: 15;
    in-out property <bool> start-with-windows: false;
    callback settings-interval-changed(int);
    callback settings-startup-changed(bool);
    callback add-google-account();          // add a new account from settings
    callback remove-google-account(string); // remove a connected account
    callback open-config-dir();

    // Browser path for OAuth
    in-out property <string> browser-path: "";
    callback browse-for-browser();
    callback browser-path-changed(string);

    // Update notification
    in property <string> app-version: "";
    in property <string> update-version: "";
    in-out property <bool> checking-for-update: false;
    callback update-now();
    callback dismiss-notification();
    callback check-for-update();

    // Error detail
    in property <string> sync-error-detail: "";
    in-out property <bool> show-error-detail: false;
    in-out property <bool> error-copy-done: false;
    callback copy-error();

    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: 12px;
        background: Theme.background;
        border-width: 1px;
        border-color: Theme.border;
        clip: true;

        VerticalLayout {

            // ── Header ────────────────────────────────────────────────────────
            Rectangle {
                height: 64px;
                background: Theme.surface;

                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 6px;

                    HorizontalLayout {
                        horizontal-stretch: 1;
                        spacing: 10px;

                        Image {
                            source: @image-url("../assets/icon.svg");
                            width: 26px; height: 26px;
                            image-fit: contain;
                            vertical-stretch: 0;
                            y: (parent.height - self.height) / 2;
                        }

                        HorizontalLayout {
                            horizontal-stretch: 0;
                            spacing: 5px;
                            alignment: center;

                            Text {
                                text: "ruscal";
                                color: Theme.text-primary;
                                font-size: 16px; font-weight: 700;
                                vertical-alignment: center;
                                letter-spacing: -0.3px;
                            }
                            Text {
                                text: app-version;
                                color: Theme.text-tertiary;
                                font-size: 10px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            width: 1px; height: 16px;
                            background: Theme.border;
                            horizontal-stretch: 0;
                            y: (parent.height - self.height) / 2;
                        }

                        SyncIndicator {
                            status: sync-status;
                            horizontal-stretch: 0;
                            y: (parent.height - self.height) / 2;
                            clicked => { root.sync-now(); }
                        }

                        if sync-status == SyncStatus.Error: Rectangle {
                            width: 18px; height: 18px;
                            border-radius: 9px;
                            background: Theme.error;
                            horizontal-stretch: 0;
                            y: (parent.height - self.height) / 2;

                            Text {
                                text: "!";
                                color: #ffffff;
                                font-size: 11px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            err-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.show-error-detail = true; }
                            }
                        }

                        Text {
                            text: last-sync-text;
                            color: Theme.text-secondary;
                            font-size: 13px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                    }

                    HorizontalLayout {
                        horizontal-stretch: 0;
                        spacing: 0px;

                        SvgIconBtn {
                            y: (parent.height - self.height) / 2;
                            icon: @image-url("../assets/settings.svg");
                            clicked => { root.open-settings(); }
                        }
                        SvgIconBtn {
                            y: (parent.height - self.height) / 2;
                            icon: @image-url("../assets/minimize.svg");
                            clicked => { root.minimize(); }
                        }
                        SvgIconBtn {
                            y: (parent.height - self.height) / 2;
                            icon: @image-url("../assets/close.svg");
                            hot-color: Theme.error;
                            hot-bg: #ff453a22;
                            clicked => { root.show-quit-dialog = true; }
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.border; }

            // ── Page 0: Pairs list ────────────────────────────────────────────
            if current-page == 0: VerticalLayout {
                vertical-stretch: 1;
                padding: 16px;
                spacing: 10px;

                // ── Update available banner ───────────────────────────────────
                if update-version != "": Rectangle {
                    height: 40px;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: Theme.warning;
                    background: Theme.warning.with-alpha(0.12);

                    HorizontalLayout {
                        padding-left: 14px; padding-right: 6px;
                        spacing: 8px;

                        Text {
                            text: "v" + update-version + " available";
                            color: Theme.warning;
                            font-size: 12px; font-weight: 500;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        // "Install" button
                        Rectangle {
                            width: 64px; height: 28px;
                            y: (parent.height - self.height) / 2;
                            border-radius: 7px;
                            border-width: 1px;
                            border-color: Theme.warning;
                            background: upd-t.has-hover ? Theme.warning : Theme.warning.with-alpha(0.15);
                            animate background { duration: 80ms; }
                            Text {
                                text: "Install";
                                color: upd-t.has-hover ? #ffffff : Theme.warning;
                                font-size: 11px; font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: 80ms; }
                            }
                            upd-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.update-now(); }
                            }
                        }

                        // Dismiss "×"
                        Rectangle {
                            width: 28px; height: 28px;
                            y: (parent.height - self.height) / 2;
                            border-radius: 6px;
                            background: dim-t.has-hover ? Theme.surface-elevated : transparent;
                            animate background { duration: 80ms; }
                            Text {
                                text: "×";
                                color: dim-t.has-hover ? Theme.text-primary : Theme.text-tertiary;
                                font-size: 16px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: 80ms; }
                            }
                            dim-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.dismiss-notification(); }
                            }
                        }
                    }
                }

                ScrollView {
                    vertical-stretch: 1;
                    viewport-height: (pairs.length - 1) * 82px + 50px;
                    VerticalLayout {
                        spacing: 10px;
                        for pair[i] in pairs: PairRow {
                            height: i < pairs.length - 1 ? 72px : 44px;
                            pair: pair;
                            configure-source => { root.configure-source(i); }
                            configure-dest   => { root.configure-dest(i); }
                            delete           => { root.delete-pair(i); }
                            clear-source     => { root.clear-source(i); }
                            clear-dest       => { root.clear-dest(i); }
                        }
                    }
                }
            }

            // ── Page 1: Source calendar picker ────────────────────────────────
            if current-page == 1: VerticalLayout {
                vertical-stretch: 1;

                Rectangle {
                    height: 48px;
                    background: Theme.surface;
                    HorizontalLayout {
                        padding-left: 4px;
                        padding-top: 5px;
                        padding-bottom: 5px;
                        spacing: 4px;
                        alignment: start;
                        SvgIconBtn {
                            icon: @image-url("../assets/chevron-left.svg");
                            clicked => { root.current-page = 0; }
                        }
                        Text {
                            text: "Choose Outlook calendar";
                            color: Theme.text-primary;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }
                Rectangle { height: 1px; background: Theme.border; }

                if outlook-calendars.length == 0: Rectangle {
                    vertical-stretch: 1;
                    Text {
                        text: "Loading calendars…";
                        color: Theme.text-secondary;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                if outlook-calendars.length > 0: ScrollView {
                    vertical-stretch: 1;
                    viewport-height: outlook-calendars.length * 60px;
                    VerticalLayout {
                        for cal[i] in outlook-calendars: Rectangle {
                            height: 60px;
                            background: cal-t.has-hover ? Theme.surface-elevated : transparent;
                            animate background { duration: 80ms; }
                            HorizontalLayout {
                                padding-left: 20px;
                                padding-right: 16px;
                                spacing: 14px;
                                Image {
                                    source: @image-url("../assets/outlook.svg");
                                    width: 24px; height: 24px;
                                    image-fit: contain;
                                    colorize: Theme.outlook-color;
                                    y: (parent.height - self.height) / 2;
                                }
                                Text {
                                    text: cal;
                                    color: Theme.text-primary;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                            }
                            Rectangle {
                                y: parent.height - 1px;
                                height: 1px;
                                background: Theme.border;
                            }
                            cal-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.source-selected(i); }
                            }
                        }
                    }
                }
            }

            // ── Page 2: Destination provider picker ───────────────────────────
            if current-page == 2: VerticalLayout {
                vertical-stretch: 1;

                Rectangle {
                    height: 48px;
                    background: Theme.surface;
                    HorizontalLayout {
                        padding-left: 4px;
                        padding-top: 5px;
                        padding-bottom: 5px;
                        spacing: 4px;
                        alignment: start;
                        SvgIconBtn {
                            icon: @image-url("../assets/chevron-left.svg");
                            clicked => { root.current-page = 0; }
                        }
                        Text {
                            text: "Choose destination";
                            color: Theme.text-primary;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }
                Rectangle { height: 1px; background: Theme.border; }

                Rectangle {
                    height: 60px;
                    background: gcal-provider-t.has-hover ? Theme.surface-elevated : transparent;
                    animate background { duration: 80ms; }
                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 16px;
                        spacing: 14px;
                        Image {
                            source: @image-url("../assets/gcal.svg");
                            width: 24px; height: 24px;
                            image-fit: contain;
                            y: (parent.height - self.height) / 2;
                        }
                        Text {
                            text: "Google";
                            color: Theme.text-primary;
                            font-size: 13px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                    }
                    Rectangle {
                        y: parent.height - 1px;
                        height: 1px;
                        background: Theme.border;
                    }
                    gcal-provider-t := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.dest-provider-selected(0); }
                    }
                }

                Rectangle { vertical-stretch: 1; }
            }

            // ── Page 3: Google Calendar picker ────────────────────────────────
            if current-page == 3: VerticalLayout {
                vertical-stretch: 1;

                Rectangle {
                    height: 48px;
                    background: Theme.surface;
                    HorizontalLayout {
                        padding-left: 4px;
                        padding-top: 5px;
                        padding-bottom: 5px;
                        spacing: 4px;
                        alignment: start;
                        SvgIconBtn {
                            icon: @image-url("../assets/chevron-left.svg");
                            clicked => { root.current-page = 2; }
                        }
                        Text {
                            text: "Choose Google Calendar";
                            color: Theme.text-primary;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }
                Rectangle { height: 1px; background: Theme.border; }

                if google-status != "": VerticalLayout {
                    vertical-stretch: 1;
                    Rectangle { vertical-stretch: 1; }
                    HorizontalLayout {
                        alignment: center;
                        Image {
                            source: @image-url("../assets/gcal.svg");
                            width: 40px; height: 40px;
                            image-fit: contain;
                        }
                    }
                    Rectangle { height: 14px; }
                    HorizontalLayout {
                        padding-left: 32px;
                        padding-right: 32px;
                        Text {
                            text: google-status;
                            color: Theme.text-secondary;
                            font-size: 13px;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                    }
                    Rectangle { vertical-stretch: 1; }
                }

                if google-status == "" && google-calendars.length > 0: ScrollView {
                    vertical-stretch: 1;
                    viewport-height: google-calendars.length * 60px;
                    VerticalLayout {
                        for cal[i] in google-calendars: Rectangle {
                            height: 60px;
                            background: gcal-t.has-hover ? Theme.surface-elevated : transparent;
                            animate background { duration: 80ms; }
                            HorizontalLayout {
                                padding-left: 20px;
                                padding-right: 16px;
                                spacing: 14px;
                                Image {
                                    source: @image-url("../assets/gcal.svg");
                                    width: 24px; height: 24px;
                                    image-fit: contain;
                                    y: (parent.height - self.height) / 2;
                                }
                                Text {
                                    text: cal;
                                    color: Theme.text-primary;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                            }
                            Rectangle {
                                y: parent.height - 1px;
                                height: 1px;
                                background: Theme.border;
                            }
                            gcal-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.dest-selected(i); }
                            }
                        }
                    }
                }

                // Account footer — chip row showing all connected accounts
                Rectangle { height: 1px; background: Theme.border; }
                Rectangle {
                    height: 52px;
                    HorizontalLayout {
                        padding-left: 12px; padding-right: 12px;
                        padding-top: 10px; padding-bottom: 10px;
                        spacing: 6px;
                        alignment: start;

                        // One chip per connected account
                        for acct in google-accounts: Rectangle {
                            width: 130px;
                            height: 32px;
                            border-radius: 16px;
                            border-width: 1px;
                            border-color: acct == google-account-email
                                ? Theme.accent : (acct-t.has-hover ? Theme.accent : Theme.border);
                            background: acct == google-account-email
                                ? Theme.accent-dim
                                : (acct-t.has-hover ? Theme.surface-elevated : Theme.surface);
                            animate background   { duration: 80ms; }
                            animate border-color { duration: 80ms; }
                            Text {
                                text: acct;
                                color: acct == google-account-email ? Theme.accent
                                     : (acct-t.has-hover ? Theme.text-primary : Theme.text-secondary);
                                font-size: 10px; font-weight: acct == google-account-email ? 600 : 400;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                overflow: elide;
                                animate color { duration: 80ms; }
                            }
                            acct-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.switch-google-account(acct); }
                            }
                        }

                        // "+ Add account" chip
                        Rectangle {
                            width: 100px;
                            height: 32px;
                            border-radius: 16px;
                            border-width: 1px;
                            border-color: add-chip-t.has-hover ? Theme.accent : Theme.border;
                            background: add-chip-t.has-hover ? Theme.accent-dim : transparent;
                            animate background   { duration: 80ms; }
                            animate border-color { duration: 80ms; }
                            Text {
                                text: "+ Add account";
                                color: add-chip-t.has-hover ? Theme.accent : Theme.text-tertiary;
                                font-size: 10px; font-weight: 500;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: 80ms; }
                            }
                            add-chip-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.settings-google-sign-out(); }
                            }
                        }
                    }
                }
            }

            // ── Page 4: Settings ──────────────────────────────────────────────
            if current-page == 4: VerticalLayout {
                vertical-stretch: 1;

                Rectangle {
                    height: 48px;
                    background: Theme.surface;
                    HorizontalLayout {
                        padding-left: 4px;
                        padding-top: 5px;
                        padding-bottom: 5px;
                        spacing: 4px;
                        alignment: start;
                        SvgIconBtn {
                            icon: @image-url("../assets/chevron-left.svg");
                            clicked => { root.current-page = 0; }
                        }
                        Text {
                            text: "Settings";
                            color: Theme.text-primary;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }
                Rectangle { height: 1px; background: Theme.border; }

                ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        padding: 20px;
                        spacing: 0px;

                        // ── Start with Windows ────────────────────────────────
                        HorizontalLayout {
                            padding-top: 4px;
                            padding-bottom: 16px;
                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 3px;
                                Text {
                                    text: "Start with Windows";
                                    color: Theme.text-primary;
                                    font-size: 13px; font-weight: 600;
                                }
                                Text {
                                    text: "Launch ruscal automatically when you log in";
                                    color: Theme.text-secondary;
                                    font-size: 12px;
                                    wrap: word-wrap;
                                }
                            }
                            SettingsToggle {
                                y: (parent.height - self.height) / 2;
                                checked: start-with-windows;
                                toggled(v) => { root.settings-startup-changed(v); }
                            }
                        }

                        Rectangle { height: 1px; background: Theme.border; }

                        // ── Sync interval ─────────────────────────────────────
                        VerticalLayout {
                            padding-top: 16px;
                            padding-bottom: 4px;
                            spacing: 10px;

                            Text {
                                text: "Sync interval";
                                color: Theme.text-primary;
                                font-size: 13px; font-weight: 600;
                            }
                            Text {
                                text: "How often ruscal automatically syncs your calendar";
                                color: Theme.text-secondary;
                                font-size: 12px;
                                wrap: word-wrap;
                            }

                            HorizontalLayout {
                                spacing: 8px;

                                for interval[i] in [5, 15, 30, 60]: Rectangle {
                                    height: 36px;
                                    horizontal-stretch: 1;
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: sync-interval-minutes == interval
                                        ? Theme.accent : Theme.border;
                                    background: sync-interval-minutes == interval
                                        ? Theme.accent-dim
                                        : (btn-t.has-hover ? Theme.surface-elevated : Theme.surface);
                                    animate background { duration: 100ms; }

                                    Text {
                                        text: interval < 60 ? interval + "m" : "1h";
                                        color: sync-interval-minutes == interval
                                            ? Theme.accent : Theme.text-secondary;
                                        font-size: 13px; font-weight: 500;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }

                                    btn-t := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            root.sync-interval-minutes = interval;
                                            root.settings-interval-changed(interval);
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { height: 20px; }
                        Rectangle { height: 1px; background: Theme.border; }

                        // ── Browser ───────────────────────────────────────────
                        HorizontalLayout {
                            padding-top: 16px;
                            padding-bottom: 16px;
                            spacing: 8px;

                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 3px;
                                Text {
                                    text: "OAuth Browser";
                                    color: Theme.text-primary;
                                    font-size: 13px; font-weight: 600;
                                }
                                Text {
                                    text: browser-path == "" ? "Uses system default browser" : browser-path;
                                    color: Theme.text-secondary;
                                    font-size: 11px;
                                    overflow: elide;
                                }
                            }

                            Rectangle {
                                height: 32px;
                                width: 70px;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: browse-t.has-hover ? Theme.accent : Theme.border;
                                background: browse-t.has-hover ? Theme.accent-dim : Theme.surface;
                                animate background   { duration: 100ms; }
                                animate border-color { duration: 100ms; }
                                y: 4px;
                                Text {
                                    text: "Browse…";
                                    color: browse-t.has-hover ? Theme.accent : Theme.text-secondary;
                                    font-size: 11px; font-weight: 500;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    animate color { duration: 100ms; }
                                }
                                browse-t := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.browse-for-browser(); }
                                }
                            }
                        }

                        Rectangle { height: 1px; background: Theme.border; }

                        // ── Google Accounts ───────────────────────────────────
                        VerticalLayout {
                            padding-top: 16px;
                            padding-bottom: 4px;
                            spacing: 8px;

                            Text {
                                text: "Google Accounts";
                                color: Theme.text-primary;
                                font-size: 13px; font-weight: 600;
                            }
                            Text {
                                text: "Accounts connected for syncing";
                                color: Theme.text-secondary;
                                font-size: 12px;
                            }

                            // One row per connected account
                            for acct in google-accounts: HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: acct;
                                    color: Theme.text-primary;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                Rectangle {
                                    width: 28px; height: 28px;
                                    border-radius: 6px;
                                    background: rm-t.has-hover ? #ff453a22 : transparent;
                                    animate background { duration: 80ms; }
                                    Image {
                                        source: @image-url("../assets/trash.svg");
                                        width: 13px; height: 13px;
                                        image-fit: contain;
                                        colorize: rm-t.has-hover ? Theme.error : Theme.text-tertiary;
                                        animate colorize { duration: 80ms; }
                                        x: (parent.width  - self.width)  / 2;
                                        y: (parent.height - self.height) / 2;
                                    }
                                    rm-t := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.remove-google-account(acct); }
                                    }
                                }
                            }

                            // "Add account" button
                            Rectangle {
                                height: 36px;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: add-btn-t.has-hover ? Theme.accent : Theme.border;
                                background: add-btn-t.has-hover ? Theme.accent-dim : Theme.surface;
                                animate background   { duration: 100ms; }
                                animate border-color { duration: 100ms; }
                                Text {
                                    text: "+ Add Google account";
                                    color: add-btn-t.has-hover ? Theme.accent : Theme.text-secondary;
                                    font-size: 12px; font-weight: 500;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    animate color { duration: 100ms; }
                                }
                                add-btn-t := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.add-google-account(); }
                                }
                            }
                        }

                        Rectangle { height: 20px; }
                        Rectangle { height: 1px; background: Theme.border; }

                        // ── Updates ───────────────────────────────────────────
                        HorizontalLayout {
                            padding-top: 16px;
                            padding-bottom: 4px;
                            spacing: 8px;

                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 2px;
                                Text {
                                    text: "ruscal " + app-version;
                                    color: Theme.text-primary;
                                    font-size: 13px; font-weight: 600;
                                }
                                Text {
                                    text: update-version != "" ? "v" + update-version + " available"
                                        : checking-for-update ? "Checking…"
                                        : "Up to date";
                                    color: update-version != "" ? Theme.warning : Theme.text-secondary;
                                    font-size: 12px;
                                }
                            }

                            Rectangle {
                                height: 32px;
                                width: 120px;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: update-version != "" ? Theme.warning
                                    : (settings-upd-t.has-hover ? Theme.accent : Theme.border);
                                background: update-version != "" ? Theme.warning.with-alpha(0.12)
                                    : (settings-upd-t.has-hover ? Theme.accent-dim : Theme.surface);
                                animate background   { duration: 100ms; }
                                animate border-color { duration: 100ms; }
                                y: 8px;

                                Text {
                                    text: update-version != "" ? "Install update"
                                        : checking-for-update ? "Checking…"
                                        : "Check for updates";
                                    color: update-version != "" ? Theme.warning
                                        : (settings-upd-t.has-hover ? Theme.accent : Theme.text-secondary);
                                    font-size: 11px; font-weight: 500;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    animate color { duration: 100ms; }
                                }
                                settings-upd-t := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        if (root.update-version != "") {
                                            root.update-now();
                                        } else {
                                            root.check-for-update();
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { height: 16px; }
                        Rectangle { height: 1px; background: Theme.border; }
                        Rectangle { height: 12px; }

                        // ── Footer ────────────────────────────────────────────
                        Rectangle {
                            Text {
                                text: "Config: %LOCALAPPDATA%\\ruscal\\";
                                color: cfg-t.has-hover ? Theme.accent : Theme.text-tertiary;
                                font-size: 11px;
                                wrap: word-wrap;
                                animate color { duration: 80ms; }
                            }
                            cfg-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.open-config-dir(); }
                            }
                        }
                    }
                }
            }
        }

        // ── Error detail overlay ──────────────────────────────────────────────
        if show-error-detail: Rectangle {
            width: 100%; height: 100%;
            background: #000000aa;

            Rectangle {
                width: 360px;
                height: 248px;
                x: (parent.width  - self.width)  / 2;
                y: (parent.height - self.height) / 2;
                border-radius: 14px;
                background: Theme.surface-elevated;
                border-width: 1px;
                border-color: Theme.border;

                VerticalLayout {
                    padding: 20px;
                    spacing: 14px;

                    HorizontalLayout {
                        alignment: space-between;
                        Text {
                            text: "Sync error";
                            color: Theme.error;
                            font-size: 14px; font-weight: 700;
                            vertical-alignment: center;
                        }
                        Rectangle {
                            width: 28px; height: 28px;
                            border-radius: 6px;
                            background: close-err-t.has-hover ? Theme.surface : transparent;
                            animate background { duration: 80ms; }
                            Text {
                                text: "×";
                                color: Theme.text-secondary;
                                font-size: 16px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            close-err-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.show-error-detail = false; }
                            }
                        }
                    }

                    Rectangle {
                        height: 130px;
                        border-radius: 8px;
                        background: Theme.background;
                        border-width: 1px;
                        border-color: Theme.border;
                        clip: true;

                        ScrollView {
                            width: parent.width;
                            height: parent.height;
                            viewport-width: parent.width - 24px;
                            VerticalLayout {
                                padding: 10px;
                                Text {
                                    text: sync-error-detail;
                                    color: Theme.text-secondary;
                                    font-size: 11px;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;

                        Rectangle {
                            height: 34px;
                            horizontal-stretch: 1;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: error-copy-done ? Theme.success : Theme.border;
                            background: error-copy-done ? Theme.success.with-alpha(0.15)
                                      : (copy-t.has-hover ? Theme.border : Theme.surface);
                            animate background   { duration: 80ms; }
                            animate border-color { duration: 80ms; }
                            Text {
                                text: error-copy-done ? "Copied!" : "Copy";
                                color: error-copy-done ? Theme.success : Theme.text-secondary;
                                font-size: 12px; font-weight: 500;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: 80ms; }
                            }
                            copy-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.copy-error(); }
                            }
                        }

                        Rectangle {
                            height: 34px;
                            horizontal-stretch: 1;
                            border-radius: 8px;
                            background: dismiss-err-t.has-hover ? Theme.error : #ff453a44;
                            animate background { duration: 80ms; }
                            Text {
                                text: "Dismiss";
                                color: dismiss-err-t.has-hover ? #ffffff : Theme.error;
                                font-size: 12px; font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: 80ms; }
                            }
                            dismiss-err-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.show-error-detail = false; }
                            }
                        }
                    }
                }
            }
        }

        // ── Quit confirmation dialog overlay ──────────────────────────────────
        if show-quit-dialog: Rectangle {
            width: 100%; height: 100%;
            background: #000000aa;

            Rectangle {
                width: 300px; height: 150px;
                x: (parent.width  - self.width)  / 2;
                y: (parent.height - self.height) / 2;
                border-radius: 14px;
                background: Theme.surface-elevated;
                border-width: 1px;
                border-color: Theme.border;

                VerticalLayout {
                    padding: 22px;
                    spacing: 14px;

                    VerticalLayout {
                        spacing: 5px;
                        Text {
                            text: "Close ruscal?";
                            color: Theme.text-primary;
                            font-size: 15px; font-weight: 700;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "Quitting will stop all syncing.";
                            color: Theme.text-secondary;
                            font-size: 13px;
                            horizontal-alignment: center;
                        }
                    }

                    HorizontalLayout {
                        spacing: 10px;

                        Rectangle {
                            height: 36px;
                            horizontal-stretch: 1;
                            border-radius: 8px;
                            background: min-t.has-hover ? Theme.surface : Theme.border;
                            animate background { duration: 100ms; }
                            Text {
                                text: "Minimize";
                                color: Theme.text-primary;
                                font-size: 13px; font-weight: 500;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            min-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.show-quit-dialog = false;
                                    root.minimize();
                                }
                            }
                        }

                        Rectangle {
                            height: 36px;
                            horizontal-stretch: 1;
                            border-radius: 8px;
                            background: quit-t.has-hover ? Theme.error : #ff453a44;
                            animate background { duration: 100ms; }
                            Text {
                                text: "Quit";
                                color: quit-t.has-hover ? #ffffff : Theme.error;
                                font-size: 13px; font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: 100ms; }
                            }
                            quit-t := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.quit(); }
                            }
                        }
                    }
                }
            }
        }
    }
}
